generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  username  String
  productId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}
